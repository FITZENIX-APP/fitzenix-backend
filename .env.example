NODE_ENV=development
PORT=3000
MongoURI=mongodb://localhost:27017/gym-saas
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# One-time: POST /api/v1/auth/register/super-admin with header x-bootstrap-key
SUPER_ADMIN_BOOTSTRAP_KEY=

DEV_ORIGIN=*
PROD_ORIGIN=https://your-frontend.com

# mock = log only; set Twilio vars for real WhatsApp
WHATSAPP_PROVIDER=mock
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Email OTP verification (Resend)
EMAIL_PROVIDER=mock
RESEND_API_KEY=
EMAIL_FROM=Gym App <onboarding@resend.dev>
